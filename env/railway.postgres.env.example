# Railway → New Project → Provision PostgreSQL
#
# Эти переменные Railway создаёт АВТОМАТИЧЕСКИ на сервисе Postgres.
# Вручную на Railway для Fakk Smoking ничего добавлять не нужно —
# приложение крутится на Vercel, не на Railway.
#
# Откройте Postgres → Variables / Connect и СКОПИРУЙТЕ в Vercel:
#   DATABASE_URL  (или DATABASE_PUBLIC_URL, если внутренний URL не достучится с Vercel)

# --- Справочно: что видите в Railway (значения подставляет Railway) ---

DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway
DATABASE_PUBLIC_URL=postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway

PGHOST=HOST.railway.app
PGPORT=5432
PGUSER=postgres
PGPASSWORD=REPLACE
PGDATABASE=railway

# Для Vercel обычно берут публичный URL с sslmode=require, например:
# postgresql://postgres:xxx@containers-us-west-xxx.railway.app:12345/railway?sslmode=require
