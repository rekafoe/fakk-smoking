# Vercel → Environment Variables → Preview (опционально, для preview-деплоев)
# Те же ключи, что и в production. DATABASE_URL можно тот же (Railway) или отдельную БД.

DATABASE_URL=postgresql://USER:PASSWORD@HOST.railway.app:PORT/railway?sslmode=require

# Для preview удобно указать URL конкретного preview или основной прод-домен.
# Если логин на preview ломается — задайте NEXTAUTH_URL = URL этого preview-деплоя.
NEXTAUTH_URL=https://your-project-git-branch.vercel.app

# Отдельный секрет для preview — по желанию; можно тот же, что в Production.
NEXTAUTH_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
