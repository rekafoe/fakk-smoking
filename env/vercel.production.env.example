# Vercel → Project → Settings → Environment Variables → Production
# Импорт: можно вставить построчно или через CLI:
#   vercel env add DATABASE_URL production
#   vercel env pull .env.vercel.local   (после настройки в UI)
#
# DATABASE_URL — скопировать из Railway (Postgres → Variables → DATABASE_URL
# или DATABASE_PUBLIC_URL). Для Vercel нужен публичный хост с SSL.

DATABASE_URL=postgresql://USER:PASSWORD@HOST.railway.app:PORT/railway?sslmode=require

# URL сайта в браузере (без слэша в конце). После своего домена — заменить и Redeploy.
NEXTAUTH_URL=https://your-project.vercel.app

# Сгенерировать один раз и не менять (иначе все сессии сбросятся):
#   openssl rand -base64 32
#   PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
NEXTAUTH_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
