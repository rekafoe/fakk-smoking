{
  "name": "fakk-smoking",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.mjs",
    "clean:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-win.ps1",
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "dev:clean:win": "npm run clean:win && powershell -NoProfile -Command \"$env:NEXT_TELEMETRY_DISABLED='1'; npm run dev\"",
    "build": "prisma generate && next build",
    "db:migrate": "prisma migrate deploy",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "generate:content": "node scripts/generate-daily-content.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.9.1",
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.2",
    "next": "^15.3.3",
    "next-auth": "^4.24.11",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "prisma": "^6.8.2",
    "typescript": "^5.8.3"
  }
}
