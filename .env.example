# Локальная разработка — скопировать в .env
# Прод: env/vercel.production.env.example → Vercel
# Railway: env/railway.postgres.env.example (справка, что копировать в Vercel)

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"